# Single source of truth for tool versions.
# Both tools/install.sh (local dev) and the GitHub Actions workflow read this file.
# Bump a version here, then commit — the pipeline picks it up on the next run.

TERRAFORM_VERSION="1.9.8"
TERRAGRUNT_VERSION="0.66.9"
CONFLUENT_CLI_VERSION="4.58.0"
PYTHON_VERSION="3.12.7"

# uv is used to install the pinned Python locally and on the runner.
UV_VERSION="0.5.4"
