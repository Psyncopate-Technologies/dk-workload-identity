# Secrets — never commit
.env
.envrc
*.env.local
SECRETS.local.md
**/SECRETS.local.md

# PowerShell workload configs — committed template is the .example file only.
powershell/config/workloads.*.json
!powershell/config/workloads.example.json
powershell/config/workloads.*.appids.json

# Downloaded tool binaries (tools/install.sh repopulates these)
tools/bin/
tools/.cache/
tools/.python/

# Terraform / Terragrunt
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.*
**/terraform.tfstate.d/
**/.terragrunt-cache/
**/terragrunt-debug.tfvars.json
**/provider.tf
**/backend.tf
*.tfvars
!*.tfvars.example
crash.log
crash.*.log

# OS / editor
.DS_Store
.idea/
*.swp
