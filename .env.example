# Copy to .env and fill in — .env is gitignored.
# Load into your shell before running terragrunt locally:
#   set -a; source .env; set +a

# ---- Confluent Cloud (Cloud API key with OrganizationAdmin) ----
# Terraform picks these up automatically via the TF_VAR_ convention.
TF_VAR_confluent_cloud_api_key=""
TF_VAR_confluent_cloud_api_secret=""

# ---- Azure tenant (Ayele's dev tenant) ----
# Used by the PowerShell scripts that create Entra app registrations.
AZURE_TENANT_ID="1b9dca15-4db4-4905-8725-d318d11c6875"

# ---- Optional overrides ----
# Pin a non-default target env for local terragrunt runs.
# ENV="dev"
